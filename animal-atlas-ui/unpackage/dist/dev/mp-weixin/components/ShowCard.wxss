.show-card {
  width: 750rpx;
  padding: 40rpx 0;
}
.show-card .inner {
  width: 600rpx;
  margin: 0 auto;
  border-radius: 30rpx;
  overflow: hidden;
  box-shadow: 0 0 20rpx rgba(0, 0, 0, 0.6);
}
.show-card .inner .img {
  width: 600rpx;
  height: 600rpx;
  display: block;
}
.show-card .inner .info {
  width: 520rpx;
  height: 250rpx;
  background-color: white;
  padding: 10rpx 40rpx;
}
.show-card .inner .info .header {
  height: 70rpx;
  display: flex;
  align-items: center;
}
.show-card .inner .info .header .name {
  font-size: 40rpx;
  font-weight: 900;
  letter-spacing: 8rpx;
}
.show-card .inner .info .header .sex {
  margin-left: 10rpx;
  width: 30rpx;
  height: 30rpx;
}
.show-card .inner .info .info-items {
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
}
.show-card .inner .info .info-items .info-item {
  width: 250rpx;
  margin-bottom: 10rpx;
  display: flex;
  align-items: center;
  font-size: 28rpx;
}
.show-card .inner .info .icon {
  width: 40rpx;
  height: 40rpx;
}
.show-card .inner .info .footer {
  display: flex;
  margin-top: 10rpx;
}
.show-card .inner .info .footer .icon {
  margin-right: 10rpx;
}
.show-card .inner .info .footer .text {
  font-size: 13px;
}